# --- SYSTEM PROFILE ---
# Options: RPI4, 8GB, 16GB, 32GB
SYSTEM_PROFILE=16GB

# --- DATABASE SETTINGS ---
DB_NAME=gis
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432
DB_HOST=localhost
CONTAINER_NAME=oscar-postgis-container

# --- SECURITY ---
# Replace before production use
KEYSTORE_PASSWORD=atakatak
TRUSTSTORE_PASSWORD=changeit

# --- OPTIONAL MEMORY / DIAGNOSTICS OVERRIDES ---
# Leave blank to use profile defaults from launch.sh
JAVACPP_MAX_BYTES=
JAVACPP_MAX_PHYSICAL_BYTES=
JFR_FILENAME=